{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hardware_schema.json",
  "title": "TritonSim Hardware Configuration",
  "description": "Schema for defining NPU/accelerator hardware parameters",
  "type": "object",
  "required": ["name", "clock", "memory_spaces", "compute_units", "data_movers"],
  
  "properties": {
    "name": {
      "type": "string",
      "description": "Hardware name (e.g., Ascend 910B)"
    },
    "vendor": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    
    "clock": {
      "type": "object",
      "required": ["frequency_ghz"],
      "properties": {
        "frequency_ghz": {
          "type": "number",
          "minimum": 0.1,
          "description": "Core clock frequency in GHz"
        },
        "cycles_per_us": {
          "type": "integer",
          "description": "Derived: cycles per microsecond"
        }
      }
    },
    
    "memory_spaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["off_chip", "on_chip_shared", "on_chip_local", "register_file"]
          },
          "size_gb": { "type": "number" },
          "size_mb": { "type": "number" },
          "size_kb": { "type": "number" },
          "bandwidth_tbps": { "type": "number" },
          "bandwidth_gbps": { "type": "number" },
          "latency_cycles": { "type": "integer" },
          "description": { "type": "string" }
        }
      }
    },
    
    "compute_units": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["matrix_engine", "simd_engine", "scalar_engine"]
          },
          "tflops_fp16": { "type": "number" },
          "tflops_fp32": { "type": "number" },
          "tflops_int8": { "type": "number" },
          "tile_m": { "type": "integer" },
          "tile_n": { "type": "integer" },
          "tile_k": { "type": "integer" },
          "width_elements": { "type": "integer" },
          "width_bytes": { "type": "integer" },
          "input_spaces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "output_space": { "type": "string" },
          "compute_space": { "type": "string" },
          "supported_ops": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supported_dtypes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    
    "data_movers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["src_space"],
        "properties": {
          "description": { "type": "string" },
          "src_space": { "type": "string" },
          "dst_space": { "type": "string" },
          "dst_spaces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "bandwidth_gbps": { "type": "number" },
          "max_burst_bytes": { "type": "integer" },
          "alignment_bytes": { "type": "integer" },
          "supports_accumulate": { "type": "boolean" },
          "supports_cast": { "type": "boolean" }
        }
      }
    },
    
    "pipeline": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "stages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": { "type": "string" }
        }
      }
    },
    
    "performance_model": {
      "type": "object",
      "description": "Custom performance estimation formulas"
    },

    "calibration": {
      "type": "object",
      "description": "Profiling-derived model parameters for this hardware generation",
      "properties": {
        "cost_model_params": {
          "type": "object",
          "description": "Named coefficients used by optional cost-model features such as tilemix",
          "additionalProperties": { "type": "number" }
        },
        "tilemix_cost_model_params": {
          "type": "object",
          "description": "Alias for tilemix-specific cost-model coefficients",
          "additionalProperties": { "type": "number" }
        },
        "parallelism": {
          "type": "object",
          "description": "Hardware parallelism and legacy launch-dispatch calibration",
          "properties": {
            "num_aic_cores": { "type": "integer", "minimum": 1 },
            "num_aiv_cores": { "type": "integer", "minimum": 1 },
            "block_launch_overhead_us": {
              "type": "number",
              "minimum": 0,
              "description": "Legacy per-block launch overhead fallback"
            }
          },
          "additionalProperties": true
        },
        "kernel_launch_overhead": {
          "type": "object",
          "description": "Kernel-level launch/dispatch overhead added to TTIR and HIVM predictions",
          "properties": {
            "target_metric": {
              "type": "string",
              "description": "Profiling metric this calibration targets, e.g. msprof_task_duration"
            },
            "model": {
              "type": "string",
              "description": "Launch model family, e.g. fixed_plus_block_dispatch_v1"
            },
            "fixed_us": { "type": "number", "minimum": 0 },
            "per_block_us": { "type": "number", "minimum": 0 },
            "per_wave_us": { "type": "number", "minimum": 0 },
            "small_kernel_body_threshold_us": { "type": "number", "minimum": 0 },
            "mode_adjust_us": {
              "type": "object",
              "description": "Optional per-kernel-mode adjustment; A5/David SIMT should be calibrated independently",
              "properties": {
                "aic": { "type": "number" },
                "aiv": { "type": "number" },
                "mix": { "type": "number" },
                "simt": { "type": "number" },
                "simd_simt_mix": { "type": "number" }
              },
              "additionalProperties": { "type": "number" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },

    "cost_model_params": {
      "type": "object",
      "description": "Top-level named cost-model coefficients",
      "additionalProperties": { "type": "number" }
    }
  }
}
